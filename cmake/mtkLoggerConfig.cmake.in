@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# mtkLogger requires Qt::Core
find_dependency(QT NAMES Qt6 Qt5 REQUIRED COMPONENTS Core)
find_dependency(Qt${QT_VERSION_MAJOR} REQUIRED COMPONENTS Core)

include("${CMAKE_CURRENT_LIST_DIR}/mtkLoggerTargets.cmake")

check_required_components(mtkLogger)
